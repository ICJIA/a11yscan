{
  "name": "a11yscan",
  "version": "1.2.0",
  "description": "Pattern-aware ARIA accessibility auditor CLI",
  "type": "module",
  "bin": {
    "a11yscan": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@axe-core/playwright": "4.10.0",
    "axe-core": "4.10.3",
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "csv-writer": "1.6.0",
    "p-limit": "6.0.0",
    "picomatch": "4.0.2",
    "playwright": "1.50.0",
    "sitemapper": "3.1.4"
  },
  "devDependencies": {
    "@types/node": "22.13.4",
    "@types/picomatch": "4.0.2",
    "typescript": "5.7.3",
    "vitest": "3.0.0"
  }
}
